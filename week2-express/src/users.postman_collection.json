      "type": "string"
    },
    {
      "key": "demoUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "seedUserAEmail",
      "value": "",
      "type": "string"
    },
    {
      "key": "seedUserAId",
      "value": "",
      "type": "string"
    },
    {
      "key": "seedUserBId",
      "value": "",
      "type": "string"
    }
  ]
