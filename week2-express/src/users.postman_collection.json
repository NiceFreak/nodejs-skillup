    {
      "name": "六、Auth 注册 · 成功与边界",
      "item": [
        {
          "name": "1. Register auth user A - 创建并保存邮箱",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Auth Demo A\",\n  \"email\": \"auth-a-{{$randomUUID}}@example.com\",\n  \"password\": \"correct horse battery staple\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Expected: 201。创建一个带 passwordHash 的认证用户；Test 自动保存邮箱给第 4 条重复邮箱请求。"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('response excludes password', () => pm.expect(body.data).to.not.have.property('password'));",
                  "pm.test('response excludes passwordHash', () => pm.expect(body.data).to.not.have.property('passwordHash'));",
                  "pm.collectionVariables.set('authDemoEmail', body.data.email);"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Register auth user B - 独立新用户",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Auth Demo B\",\n  \"email\": \"auth-b-{{$randomUUID}}@example.com\",\n  \"password\": \"a long memorable demo passphrase\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Expected: 201。使用随机 UUID 邮箱，可重复运行并持续创建新用户。"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('safe response fields', () => {",
                  "  pm.expect(body.data).to.have.all.keys('name', 'email');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Register auth user C - 独立新用户",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Auth Demo C\",\n  \"email\": \"auth-c-{{$randomUUID}}@example.com\",\n  \"password\": \"another secure demo passphrase\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Expected: 201。第三个认证用户，用于在 Compass / GET /users 中观察结果。"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('password fields are absent', () => {",
                  "  pm.expect(body.data).to.not.have.property('password');",
                  "  pm.expect(body.data).to.not.have.property('passwordHash');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4. Register - duplicate email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Duplicate Auth User\",\n  \"email\": \"{{authDemoEmail}}\",\n  \"password\": \"correct horse battery staple\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Expected: 409。依赖第 1 条保存的 authDemoEmail，验证唯一索引与错误翻译链。"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 409', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        },
        {
          "name": "5. Register - password too short",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Weak Password User\",\n  \"email\": \"weak-{{$randomUUID}}@example.com\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Expected: 400。验证 auth service 的最低 15 位密码策略。"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        }
      ],
      "description": "建议按 1 → 2 → 3 → 4 → 5 执行。前三条会创建并保留认证用户；第 4 条依赖第 1 条保存的邮箱；第 5 条不会创建用户。"
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "missingUserId",
      "value": "000000000000000000000000",
      "type": "string"
    },
    {
      "key": "demoUserId",
