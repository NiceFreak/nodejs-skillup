{
  "info": {
    "_postman_id": "7b1f2a91-4f17-4d6a-a5d4-nodejs-skillup-users",
    "name": "Week2 Express Users",
    "description": "Manual CRUD/demo requests for the Week2 Express users API. Update variables before demo when needed.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List users",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        },
        "description": "Expected: 200 and an array of users."
      }
    },
    {
      "name": "Get one user by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{existingUserId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{existingUserId}}"
          ]
        },
        "description": "Replace existingUserId with a real MongoDB _id first. Expected after replacement: 200 and one user object."
      }
    },
    {
      "name": "Get user with invalid ObjectId format",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "1"
          ]
        },
        "description": "Expected: 400 because the id is not a valid MongoDB ObjectId string."
      }
    },
    {
      "name": "Get user with valid ObjectId format but no matching user",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{missingUserId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{missingUserId}}"
          ]
        },
        "description": "Expected: 404 because the id format is valid but no user should exist with this _id."
      }
    },
    {
      "name": "Create user - success path",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman User\",\n  \"email\": \"postman-user-{{$timestamp}}@example.com\",\n  \"age\": 28,\n  \"addresses\": [\n    {\n      \"recipient\": \"Postman User\",\n      \"phone\": \"13800000000\",\n      \"province\": \"Shanghai\",\n      \"city\": \"Shanghai\",\n      \"detailAddress\": \"Demo Road 1\"\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        },
        "description": "Expected: 201 and a new user JSON with MongoDB-generated _id. After sending, refresh Compass and confirm the document was inserted. Copy the returned _id to the createdUserId collection variable if you want to run the next request."
      }
    },
    {
      "name": "Get user created by success request",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{createdUserId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{createdUserId}}"
          ]
        },
        "description": "Set createdUserId to the _id returned by Create user - success path. Expected: 200 and that same user."
      }
    },
    {
      "name": "Create duplicate email seed",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Duplicate Email Seed\",\n  \"email\": \"{{duplicateEmail}}\",\n  \"age\": 30\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        },
        "description": "Send this once before the duplicate-email request. Expected: 201 if duplicateEmail does not exist yet. If it already returns 409, change duplicateEmail before demo."
      }
    },
    {
      "name": "Create user - duplicate email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Duplicate Email Again\",\n  \"email\": \"{{duplicateEmail}}\",\n  \"age\": 31\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        },
        "description": "Expected: 409 after the duplicate email seed request has succeeded once."
      }
    },
    {
      "name": "Create user - missing email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Missing Email User\",\n  \"age\": 20\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        },
        "description": "Expected: 400 because email is required by the User model."
      }
    },
    {
      "name": "Create user - missing name",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"missing-name-{{$timestamp}}@example.com\",\n  \"age\": 20\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        },
        "description": "Expected: 400 because name is required by the User model."
      }
    },
    {
      "name": "Delete user - success path",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{existingUserId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{existingUserId}}"
          ]
        },
        "description": "Replace existingUserId with a real _id from MongoDB Compass or the create response above. Expected: 200 and a success message. After sending, refresh Compass and confirm the document was deleted."
      }
    },
    {
      "name": "Delete user - invalid ObjectId format",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "1"
          ]
        },
        "description": "Expected: 400 because the id is not a valid MongoDB ObjectId string."
      }
    },
    {
      "name": "Delete user - valid ObjectId format but no matching user",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{missingUserId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{missingUserId}}"
          ]
        },
        "description": "Expected: 404 because the id format is valid but no user should exist with this _id."
      }
    },
    {
      "name": "Delete user - already deleted",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{existingUserId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{existingUserId}}"
          ]
        },
        "description": "User not found because it was already deleted in the previous Delete user - success path request. Expected: 404."
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "existingUserId",
      "value": "000000000000000000000000",
      "type": "string"
    },
    {
      "key": "createdUserId",
      "value": "000000000000000000000000",
      "type": "string"
    },
    {
      "key": "missingUserId",
      "value": "000000000000000000000000",
      "type": "string"
    },
    {
      "key": "duplicateEmail",
      "value": "skillup.duplicate@example.com",
      "type": "string"
    }
  ]
}
