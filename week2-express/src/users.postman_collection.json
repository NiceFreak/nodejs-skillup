    {
      "name": "五、聚合报表 · 客户消费与月度趋势",
      "item": [
        {
          "name": "1. Customer spending - 最近 30 天客户消费",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reports/customer-spending?status=completed&days=30",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reports",
                "customer-spending"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "completed"
                },
                {
                  "key": "days",
                  "value": "30"
                }
              ]
            },
            "description": "Expected: 200 + 数组。每条是一个有 completed 订单的客户，包含订单数、总消费、均单以及 lookup 得到的姓名/邮箱，按总消费降序。"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('response is an array', () => pm.expect(body).to.be.an('array'));",
                  "pm.test('report row has display fields', () => {",
                  "  if (body.length > 0) pm.expect(body[0]).to.include.all.keys('userId', 'customerName', 'customerEmail', 'orderCount', 'totalSpending', 'avgOrderValue');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Monthly sales - 最近 6 个自然月",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reports/monthly-sales?status=completed&months=6",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reports",
                "monthly-sales"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "completed"
                },
                {
                  "key": "months",
                  "value": "6"
                }
              ]
            },
            "description": "Expected: 200 + 最多 6 条月度汇总。months=6 表示包含当前月在内的最近 6 个自然月；每条汇总当月 completed 订单，不是订单明细。"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('response is an array', () => pm.expect(body).to.be.an('array'));",
                  "pm.test('at most 6 calendar-month rows', () => pm.expect(body.length).to.be.at.most(6));",
                  "pm.test('monthly row has display fields', () => {",
                  "  if (body.length > 0) pm.expect(body[0]).to.include.all.keys('year', 'month', 'orderCount', 'totalSpending', 'avgOrderValue');",
                  "});"
                ]
              }
            }
          ]
