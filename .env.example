# 复制本文件为 .env 并填入真实值；.env 已被 .gitignore 忽略，不会提交

# MongoDB 连接
MONGODB_URI=mongodb://root:example@localhost:27017/shop?authSource=admin

# 后端服务端口（可选，默认 3000）
PORT=3000

# JWT 签名密钥（必填，长度需 ≥ 32；服务启动时校验，不足会拒绝启动）
JWT_SECRET=replace-with-a-random-string-at-least-32-chars

# 第 7 周 AI 集成时使用，切勿把真实 key 写进被提交的文件
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
